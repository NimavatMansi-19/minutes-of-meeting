generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

model meetingmember {
  MeetingMemberID Int       @id @default(autoincrement())
  MeetingID       Int
  StaffID         Int
  IsPresent       Boolean?  @default(false)
  Remarks         String?   @db.VarChar(255)
  Created         DateTime? @default(now()) @db.DateTime(0)
  Modified        DateTime? @default(now()) @db.DateTime(0)
  meetings        meetings  @relation(fields: [MeetingID], references: [MeetingID])
  staff           staff     @relation(fields: [StaffID], references: [StaffID])

  @@index([MeetingID], map: "fk_meetingmember_meeting_rel")
  @@index([StaffID], map: "fk_meetingmember_staff_rel")
}

model meetings {
  MeetingID            Int       @id @default(autoincrement())
  MeetingDate          DateTime  @db.DateTime(0)
  MeetingTypeID        Int
  MeetingDescription   String?   @db.VarChar(255)
  DocumentPath         String?   @db.VarChar(255)
  Created              DateTime? @default(now()) @db.DateTime(0)
  Modified             DateTime? @default(now()) @db.DateTime(0)
  IsCancelled          Boolean?  @default(false)
  CancellationDateTime DateTime? @db.DateTime(0)
  CancellationReason   String?   @db.VarChar(255)
  CreatedBy            Int?      @default(0)
  meetingtype          meetingtype @relation(fields: [MeetingTypeID], references: [MeetingTypeID])
  meetingmember       meetingmember[]
  meetingminutes      meetingminutes[]
  meetingagenda       meetingagenda[]
  minuteshistory      minuteshistory[]
  actionitem          actionitem[]
  decision            decision[]

  @@index([MeetingTypeID], map: "fk_meetings_meetingtype_rel")
}

model meetingtype {
  MeetingTypeID   Int       @id @default(autoincrement())
  MeetingTypeName String    @db.VarChar(100)
  Remarks         String?   @db.VarChar(255)
  Created         DateTime? @default(now()) @db.DateTime(0)
  Modified        DateTime? @default(now()) @db.DateTime(0)
  meetings        meetings[]
}

model staff {
  StaffID      Int       @id @default(autoincrement())
  StaffName    String    @db.VarChar(100)
  MobileNo     String?   @db.VarChar(15)
  EmailAddress String?   @db.VarChar(100)
  Remarks      String?   @db.VarChar(255)
  Created      DateTime? @default(now()) @db.DateTime(0)
  Modified     DateTime? @default(now()) @db.DateTime(0)
  meetingmember meetingmember[]
  notification  notification[]
  actionitem    actionitem[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  user_id  Int     @id @default(autoincrement())
  name     String? @db.VarChar(100)
  email    String? @unique(map: "email") @db.VarChar(100)
  password String? @db.VarChar(255)
  role     String  @db.VarChar(30)
}

model meetingminutes {
  MeetingMinuteID Int       @id @default(autoincrement())
  MeetingID       Int
  Notes           String    @db.Text
  Created         DateTime? @default(now()) @db.DateTime(0)
  Modified        DateTime? @default(now()) @db.DateTime(0)
  CreatedBy       Int?      @default(0)
  meetings        meetings  @relation(fields: [MeetingID], references: [MeetingID])

  @@index([MeetingID], map: "fk_meeting_minutes")
}

model meetingagenda {
  AgendaID    Int       @id @default(autoincrement())
  MeetingID   Int
  Title       String    @db.VarChar(255)
  Description String?   @db.Text
  OrderSeq    Int       @default(0)
  IsCompleted Boolean   @default(false)
  Created     DateTime? @default(now()) @db.DateTime(0)
  Modified    DateTime? @default(now()) @db.DateTime(0)
  CreatedBy   Int?      @default(0)
  meetings    meetings  @relation(fields: [MeetingID], references: [MeetingID])

  @@index([MeetingID], map: "fk_meeting_agenda")
}

model notification {
  NotificationID Int       @id @default(autoincrement())
  StaffID        Int
  Message        String    @db.VarChar(255)
  IsRead         Boolean   @default(false)
  Created        DateTime? @default(now()) @db.DateTime(0)
  staff          staff     @relation(fields: [StaffID], references: [StaffID])

  @@index([StaffID], map: "fk_notification_staff")
}

model minuteshistory {
  HistoryID   Int       @id @default(autoincrement())
  MeetingID   Int
  Content     String    @db.Text
  EditedBy    Int
  Created     DateTime? @default(now()) @db.DateTime(0)
  meetings    meetings  @relation(fields: [MeetingID], references: [MeetingID])

  @@index([MeetingID], map: "fk_minutes_history")
}

model actionitem {
  ActionItemID Int       @id @default(autoincrement())
  MeetingID    Int
  AssignedTo   Int       
  Title        String    @db.VarChar(255)
  DueDate      DateTime? @db.DateTime(0)
  Status       String    @default("Pending") @db.VarChar(50) 
  Created      DateTime? @default(now()) @db.DateTime(0)
  Modified     DateTime? @default(now()) @db.DateTime(0)
  CreatedBy    Int?      @default(0)
  meetings     meetings  @relation(fields: [MeetingID], references: [MeetingID])
  staff        staff     @relation(fields: [AssignedTo], references: [StaffID])

  @@index([MeetingID], map: "fk_actionitem_meeting")
  @@index([AssignedTo], map: "fk_actionitem_staff")
}

model decision {
  DecisionID   Int       @id @default(autoincrement())
  MeetingID    Int
  Title        String    @db.VarChar(255)
  Description  String?   @db.Text
  Status       String    @default("Active") @db.VarChar(50) 
  Created      DateTime? @default(now()) @db.DateTime(0)
  Modified     DateTime? @default(now()) @db.DateTime(0)
  CreatedBy    Int?      @default(0)
  meetings     meetings  @relation(fields: [MeetingID], references: [MeetingID])

  @@index([MeetingID], map: "fk_decision_meeting")
}
